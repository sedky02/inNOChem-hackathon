# Local dev default is zero-setup SQLite. For Postgres use:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/greendye
DATABASE_URL=sqlite+aiosqlite:///./greendye.db

JWT_ALGORITHM=HS256
JWT_SECRET=dev-secret-change-me
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Redis is optional for local API-only runs.
# REDIS_URL=redis://localhost:6379/0

# Celery is separated from the API process. Set these when running a worker.
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# S3_BUCKET_NAME=greendye-exports
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=
MODEL_BASE_PATH=./models/
# SENTRY_DSN=
AUTO_CREATE_TABLES=true
SEED_ON_STARTUP=false
